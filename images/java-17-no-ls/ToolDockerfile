# syntax=docker/dockerfile:1
# Theia IDE for Java with External Language Server
# This image contains Java tooling (JDK, Maven) but connects to an external
# language server via TCP instead of using an embedded one.

# Load the base-ide image, only copy from here
ARG BASE_IDE_TAG=latest
ARG BASE_IMAGE=ghcr.io/eduide/eduide/base:${BASE_IDE_TAG}
FROM ${BASE_IMAGE} AS base-ide

# Parallel stage: Install system dependencies (runs concurrently with plugin-image) 
FROM ubuntu:24.04 AS apt-deps

# Create theia user and directories first (doesn't need apt)
RUN useradd --system --create-home --user-group --uid 101 theia && \
    chmod g+rw /home && \
    mkdir -p /home/project && \
    chown -R theia:theia /home/theia && \
    chown -R theia:theia /home/project

# Configure APT proxy if provided
ARG APT_HTTP_PROXY
RUN if [ -n "$APT_HTTP_PROXY" ]; then \
      echo "Acquire::http::Proxy \"$APT_HTTP_PROXY\";" > /etc/apt/apt.conf.d/01proxy; \
      sed -i 's|https://|http://|g' /etc/apt/sources.list.d/*.sources 2>/dev/null || true; \
      sed -i 's|https://|http://|g' /etc/apt/sources.list 2>/dev/null || true; \
    fi

# Install required tools for Java development (no embedded language server)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 update && \
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 install -y --no-install-recommends \
    bash zsh curl git openssh-client openssh-server libsecret-1-0 \
    openjdk-17-jdk maven ca-certificates && \
    apt-get autoremove -y

# Clean up APT proxy config if it was set
RUN rm -f /etc/apt/apt.conf.d/01proxy

# Parallel stage: Plugin download (runs concurrently with apt-deps)
FROM node:22-bullseye AS plugin-image

WORKDIR /home/theia

# Configure to skip download of puppeteer
ENV PUPPETEER_SKIP_DOWNLOAD=true

# Copy required configuration files
COPY --from=base-ide /home/theia/package.json ./package.json.base
COPY images/java-17-no-ls/package.json.patch ./package.json.patch

# Merge the base package.json with the patch using Node.js
RUN node -e "const fs=require('fs'); const deepMerge=(t,s)=>{const o={...t}; for(const k in s){o[k]=s[k]!==null&&typeof s[k]==='object'&&!Array.isArray(s[k])&&t[k]?deepMerge(t[k],s[k]):s[k]} return o}; const base=JSON.parse(fs.readFileSync('package.json.base')); const patch=JSON.parse(fs.readFileSync('package.json.patch')); fs.writeFileSync('package.json', JSON.stringify(deepMerge(base,patch), null, 2));" && \
    rm package.json.base package.json.patch

# Copy from base-ide: scripts, configs, existing plugins, and production node_modules
COPY --from=base-ide /home/theia/scripts /home/theia/scripts
COPY --from=base-ide /home/theia/configs /home/theia/configs
COPY --from=base-ide /home/theia/tsconfig.json /home/theia/tsconfig.json
COPY --from=base-ide /home/theia/plugins /home/theia/plugins
COPY --from=base-ide /home/theia/node_modules /home/theia/node_modules

# Install ONLY @theia/cli (needed for download:plugins command)
# This is much faster than full yarn install since we already have prod node_modules
ARG NPM_REGISTRY
RUN if [ -n "$NPM_REGISTRY" ]; then yarn config set registry "$NPM_REGISTRY"; fi \
    && yarn add -W @theia/cli@1.68.2 --network-timeout 1000000

# Download Java plugins and external LS connector
RUN --mount=type=cache,id=theia-plugin-cache-java-17-no-ls,target=/home/theia/.plugin-cache,sharing=locked \
    yarn download:plugins:smart

# Final stage: Assemble the application
FROM apt-deps AS final-ide

# Copy Node.js from plugin-image (required for Theia runtime)
COPY --from=plugin-image /usr/local/bin/node /usr/local/bin/
COPY --from=plugin-image /usr/local/lib/node_modules/ /usr/local/lib/node_modules/

# Switch to Theia user
USER theia
ENV HOME=/home/theia
WORKDIR /home/theia

# Copy application from the base image (includes prod node_modules)
COPY --from=base-ide --chown=theia:theia /home/theia /home/theia

# Copy additional plugins (Java extensions + theia-lsp connector)
COPY --from=plugin-image --chown=theia:theia /home/theia/plugins /home/theia/plugins

# Install Oh My Zsh and plugins with pinned versions
RUN n=0; until rm -rf ${HOME}/.oh-my-zsh && git clone --depth 1 --branch master https://github.com/ohmyzsh/ohmyzsh.git ${HOME}/.oh-my-zsh; do \
        n=$((n+1)); \
        if [ "$n" -ge 5 ]; then echo "oh-my-zsh clone failed after $n attempts" >&2; exit 1; fi; \
        echo "oh-my-zsh clone failed (attempt $n), retrying..."; \
        sleep $((n*2)); \
    done && \
    n=0; until rm -rf ${HOME}/.oh-my-zsh/custom/plugins/zsh-autosuggestions && git clone --depth 1 --branch v0.7.1 https://github.com/zsh-users/zsh-autosuggestions ${HOME}/.oh-my-zsh/custom/plugins/zsh-autosuggestions; do \
        n=$((n+1)); \
        if [ "$n" -ge 5 ]; then echo "zsh-autosuggestions clone failed after $n attempts" >&2; exit 1; fi; \
        echo "zsh-autosuggestions clone failed (attempt $n), retrying..."; \
        sleep $((n*2)); \
    done && \
    n=0; until rm -rf ${HOME}/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting && git clone --depth 1 --branch 0.8.0 https://github.com/zsh-users/zsh-syntax-highlighting.git ${HOME}/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting; do \
        n=$((n+1)); \
        if [ "$n" -ge 5 ]; then echo "zsh-syntax-highlighting clone failed after $n attempts" >&2; exit 1; fi; \
        echo "zsh-syntax-highlighting clone failed (attempt $n), retrying..."; \
        sleep $((n*2)); \
    done

# Copy centralized zsh configuration
COPY --chown=theia:theia configs/zshrc ${HOME}/.zshrc

# Copy the project configuration files with Java-specific settings
COPY --chown=theia:theia images/java-17-no-ls/project /home/project

EXPOSE 3000

# Specify default shell for Theia and the Built-In plugins directory
ENV SHELL=/bin/zsh \
    THEIA_DEFAULT_PLUGINS=local-dir:/home/theia/plugins

# Use installed git instead of dugite
ENV USE_LOCAL_GIT=true

WORKDIR /home/theia/applications/browser

# Launch the backend application via node
ENTRYPOINT [ "node", "/home/theia/applications/browser/lib/backend/main.js" ]

# Arguments passed to the application
CMD [ "/home/project", "--hostname=0.0.0.0" ]
